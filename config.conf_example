#publish-host: FASTAPI_HOST
#required: FastAPI bind host
FASTAPI_HOST=127.0.0.1

#required: JUGO internal web UI port
JUGO_PORT=11001

#blank-if: USE_TMUX=false JUGO_TMUX_SESSION_PREFIX
#required: JUGO tmux integration switch
USE_TMUX=false

#required: JUGO shell tmux mode
TMUX_SHELL=false

#required: JUGO tmux session prefix
JUGO_TMUX_SESSION_PREFIX=jugo
